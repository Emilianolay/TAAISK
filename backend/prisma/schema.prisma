// --- 1. CONFIGURACIÓN DE PRISMA Y BASE DE DATOS ---
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 2. TABLA DE USUARIOS ---
model Usuario {
  id                  String   @id @default(uuid())
  nombre              String?
  correo              String   @unique
  contrasena          String
  rachaActual         Int      @default(0)
  mejorRacha          Int      @default(0)
  tareasCompletadas   Int      @default(0)
  fechaCreacion       DateTime @default(now())
  
  // Relación: Un usuario puede tener muchas tareas
  tareas              Tarea[]
}

// --- 3. OPCIONES PARA LAS TAREAS ---
enum EstadoTarea {
  POR_HACER
  EN_PROGRESO
  COMPLETADO
}

enum PrioridadTarea {
  BAJA
  MEDIA
  ALTA
}

// --- 4. TABLA DE TAREAS DETALLADA ---
model Tarea {
  id          String         @id @default(uuid())
  titulo      String
  descripcion String?      
  estado      EstadoTarea    @default(POR_HACER)
  prioridad   PrioridadTarea @default(BAJA)
  fechaLimite DateTime?    
  archivoUrl  String?      
  etiquetas   String[]     
  posicion    Int            @default(0)
  
  // Relación: Esta tarea pertenece a un usuario específico
  usuarioId   String
  usuario     Usuario        @relation(fields: [usuarioId], references: [id])
  fechaCreacion DateTime   @default(now())
}